llm:
  agent: codex            # codex | claude | gemini | openai
  model: gpt-5-codex
  api_key: ""             # 비워두면 로컬 CLI fallback 사용

search:
  kipris_api_key: ""      # KIPRIS Open API 키 (없으면 검색 skip)
  max_results: 20

rag:
  embedding_model: BAAI/bge-m3
  # Qdrant local path or server URL can be customized in config.yaml
  vector_db: qdrant
  chunk_size: 512
  chunk_overlap: 64

output:
  format: json            # json | csv
  dir: ./output
